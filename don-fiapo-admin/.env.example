# Database
DATABASE_URL="file:./dev.db"

# ============================================
# On-Chain Treasury Integration
# ============================================

# Lunes Network RPC (WSS)
# Mainnet options: wss://ws.lunes.io, wss://ws-lunes-main-01.lunes.io, wss://ws-archive.lunes.io
LUNES_RPC_URL=wss://ws.lunes.io

# Lunes Treasury Wallet Addresses (Substrate SS58 format)
# team_wallet - receives FIAPO from marketplace/staking/core fees
LUNES_TEAM_WALLET=
# burn_wallet - receives FIAPO for burning
LUNES_BURN_WALLET=
# Core FIAPO token contract address (PSP22)
LUNES_CORE_CONTRACT=

# ============================================
# ICO Contract (NFTs Mineradores)
# ============================================
# Endereço do contrato fiapo_ico na Lunes Network
ICO_CONTRACT=

# ============================================
# Staking Contract (Pools de Staking)
# ============================================
# Endereço do contrato fiapo_staking na Lunes Network
STAKING_CONTRACT=

# ============================================
# Airdrop Contract (Distribuição de Tokens)
# ============================================
# Endereço do contrato fiapo_airdrop na Lunes Network
AIRDROP_CONTRACT=

# ============================================
# Governance Contract (Propostas & Votação)
# ============================================
# Endereço do contrato fiapo_governance na Lunes Network
GOVERNANCE_CONTRACT=

# ============================================
# Rewards Contract (Rankings & Recompensas)
# ============================================
# Endereço do contrato fiapo_rewards na Lunes Network
REWARDS_CONTRACT=

# ============================================
# Lottery Contract (Sorteios)
# ============================================
# Endereço do contrato fiapo_lottery na Lunes Network
LOTTERY_CONTRACT=

# ============================================
# Noble Affiliate Contract (Order of Nobles)
# ============================================
# Endereço do contrato noble_affiliate na Lunes Network
NOBLE_CONTRACT=

# ============================================
# Affiliate Contract (Sistema de Afiliados 2 Níveis)
# ============================================
# Endereço do contrato fiapo_affiliate na Lunes Network
AFFILIATE_CONTRACT=

# ============================================
# Oracle Multisig Contract (Pagamentos Solana)
# ============================================
ORACLE_CONTRACT=

# ============================================
# Security Contract (Reentrância, Rate Limiting)
# ============================================
SECURITY_CONTRACT=

# ============================================
# Timelock Contract (Delays Obrigatórios)
# ============================================
TIMELOCK_CONTRACT=

# ============================================
# Upgrade Contract (Proxy & Versionamento)
# ============================================
UPGRADE_CONTRACT=

# ============================================
# Marketplace Contract (NFT Marketplace)
# ============================================
# Endereço do contrato fiapo_marketplace na Lunes Network
MARKETPLACE_CONTRACT=

# ============================================
# NFT Collections Contract (Blockchain Sync)
# ============================================
# Endereço do contrato fiapo_nft_collections na Lunes Network
NFT_COLLECTIONS_CONTRACT=
# Seed phrase da wallet admin (server-side only, para assinar transações)
# ATENÇÃO: Nunca exponha no frontend! Apenas backend (API routes)
LUNES_ADMIN_SEED=

# Solana RPC
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Solana Treasury Wallet (receives USDT/USDC from ICO, Spins, etc.)
SOLANA_RECEIVER_WALLET=

# Solana Token Mint Addresses (Mainnet)
SOLANA_USDT_MINT=Es9vMFrzaCERmJfrF4H2FYD4KCoNkY11McCe8BenwNYB
SOLANA_USDC_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v

# ============================================
# Pinata / IPFS (Upload de arte NFT)
